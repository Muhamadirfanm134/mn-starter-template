# =====================================================================
# App Starter — contoh environment variables.
# Salin ke .env.local untuk dev. Di Vercel, set per-environment
# (Production / Preview-staging) via Project Settings → Environment Variables.
# =====================================================================

# --- App / rilis ---
# production | staging | development  (menentukan label versi & robots noindex)
NEXT_PUBLIC_APP_ENV=development
# URL kanonik per environment (sitemap, robots, dll.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Feature flags (Vercel Flags SDK) ---
# Default OFF bila tidak diset. Set "true" untuk mengaktifkan per-environment.
# Secret untuk endpoint discovery flag (Vercel Toolbar). Generate: openssl rand -hex 32
FLAGS_SECRET=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Web Push (VAPID) ---
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
